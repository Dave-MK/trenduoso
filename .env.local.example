# ─────────────────────────────────────────────────────────────
# Environment variables — copy to .env.local for local dev,
# and add the same keys in your host's dashboard (e.g. Vercel →
# Project → Settings → Environment Variables) for production.
#
# NEXT_PUBLIC_* values are exposed to the browser. Everything
# else is server-only — never expose service-role / secret keys.
# Every var below is read by the code; names must match exactly.
# ─────────────────────────────────────────────────────────────

# ── Supabase (required) ──────────────────────────────────────
# Project URL + anon key: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key (server-only): same page, "service_role" secret.
# Used by account deletion and the Stripe webhook to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Polygon.io (optional) ────────────────────────────────────
# Real market candles for lessons. If unset, the app falls back
# to bundled demo candles — everything still works without it.
POLYGON_API_KEY=your-polygon-key

# ── Stripe (required only if you enable paid plans) ──────────
# Without these, billing routes return 503 and the rest of the
# app works fine. Keys: Stripe dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret: Stripe → Developers → Webhooks → your
# endpoint (must point at https://your-domain/api/stripe-webhook).
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for the Pro plan (Stripe → Product catalog → your prices).
# NOTE: these are read client-side, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_...
